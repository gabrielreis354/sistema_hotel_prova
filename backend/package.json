{
  "name": "sistema-hotel-prova-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "migrate": "npx sequelize-cli db:migrate --config ./src/database/config.js --migrations-path ./src/database/migrations --seeders-path ./src/database/seeders",
    "migrate:undo": "npx sequelize-cli db:migrate:undo:all --config ./src/database/config.js --migrations-path ./src/database/migrations --seeders-path ./src/database/seeders",
    "seed": "npx sequelize-cli db:seed:all --config ./src/database/config.js --seeders-path ./src/database/seeders"
  },
  "dependencies": {
    "bcrypt": "^5.1.0",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.11.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.34.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.14.4",
    "sequelize-cli": "^6.6.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.6.2"
  },
  "overrides": {
    "@mapbox/node-pre-gyp": "^2.0.3",
    "tar": "^7.5.15",
    "uuid": "^14.0.0"
  }
}
