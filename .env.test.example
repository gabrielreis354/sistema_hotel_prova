# Exemplo de ambiente de TESTES automatizados (vitest).
# Copie para .env.test e ajuste conforme seu Postgres local.
#   cp .env.test.example .env.test
#
# O globalSetup dos testes cria o banco 'gestao_hotel_test' e faz DROP+CREATE
# de todas as tabelas (sync force:true) — NUNCA aponte para o banco de produção.
NODE_ENV=test

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=gestao_hotel_test
POSTGRES_USER=hotel_user
POSTGRES_PASSWORD=hotel_password

JWT_SECRET=pms_hotel_test_secret_2026
