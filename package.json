{
  "name": "sistema-gestao-hotel-backend",
  "version": "1.0.0",
  "description": "Backend do Sistema de Gestão de Hotel (SaaS Multi-Tenant) em JavaScript ESModules",
  "main": "_web.js",
  "type": "module",
  "scripts": {
    "start": "node _web.js",
    "dev": "nodemon _web.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "setup:db": "psql -h ${POSTGRES_HOST:-localhost} -U ${POSTGRES_USER:-postgres} -d ${POSTGRES_DB:-gestao_hotel} -f db/schema.sql",
    "seed:db": "psql -h ${POSTGRES_HOST:-localhost} -U ${POSTGRES_USER:-postgres} -d ${POSTGRES_DB:-gestao_hotel} -f seed/seed_hotels.sql"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1084.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.19.1",
    "pg": "^8.12.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.3",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.9"
  },
  "private": true
}
